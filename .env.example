# sunsetbot.top
SUNSET_SUNSETBOT_BASE_URL=https://sunsetbot.top/
SUNSET_SUNSETBOT_MODEL=EC
SUNSET_DEFAULT_CITY=珠海

# 飞书自定义机器人 Webhook
SUNSET_FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx
SUNSET_FEISHU_WEBHOOK_SECRET=

# 通知阈值 (鲜艳度 >= 此值时推送)
SUNSET_NOTIFY_MIN_QUALITY=0.2

# 数据库
SUNSET_DATABASE_URL=sqlite+aiosqlite:///./data/sunset.db

# 珠海经纬度
SUNSET_LATITUDE=22.27
SUNSET_LONGITUDE=113.58

# 高德地图 JS API Key
SUNSET_AMAP_KEY=your_amap_key_here
